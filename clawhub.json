{
  "emoji": "⚽",
  "primaryEnv": "SIMMER_API_KEY",
  "requires": {
    "env": [
      "SIMMER_API_KEY"
    ],
    "pip": [
      "simmer-sdk>=0.17.1"
    ]
  },
  "envVars": [
    {
      "name": "SIMMER_API_KEY",
      "required": true,
      "description": "Simmer SDK API key"
    }
  ],
  "cron": null,
  "autostart": false,
  "automaton": {
    "managed": true,
    "entrypoint": "player_goal_value.py"
  },
  "tunables": [
    {
      "env": "SIMMER_WCPGV_MIN_EDGE",
      "type": "number",
      "default": 0.06,
      "range": [0.01, 0.30],
      "step": 0.01,
      "label": "Minimum model edge"
    },
    {
      "env": "SIMMER_WCPGV_MAX_POSITION",
      "type": "number",
      "default": 12,
      "range": [1, 200],
      "step": 1,
      "label": "Max position per market (USD)"
    },
    {
      "env": "SIMMER_WCPGV_DAILY_BUDGET",
      "type": "number",
      "default": 40,
      "range": [10, 1000],
      "step": 5,
      "label": "Daily budget"
    },
    {
      "env": "SIMMER_WCPGV_MAX_TRADES",
      "type": "number",
      "default": 3,
      "range": [1, 20],
      "step": 1,
      "label": "Max trades per run"
    }
  ]
}
